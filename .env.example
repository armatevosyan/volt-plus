# Set to "true" to allow POST /api/auth/register (admin signup). Any other value or unset = disabled.
ALLOW_CREATE_ADMIN="false"

DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/volt_plus"
NEXTAUTH_SECRET="replace-with-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Cloudflare R2 — used in production only (`next build` / `next start`). Dev uses `public/uploads/` + `/uploads/...`.
R2_ACCOUNT_ID="your_cloudflare_account_id"
R2_ACCESS_KEY_ID="..."
R2_SECRET_ACCESS_KEY="..."
R2_BUCKET_NAME="volt-plus"
R2_PUBLIC_URL="https://pub-xxxx.r2.dev"
